{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    { "src": "api/*.php", "use": "vercel-php" },
    { "src": "algraphybackend/public/*.php", "use": "vercel-php" },
    { "src": "index.php", "use": "vercel-php" }
  ],
  "redirects": [
    { "source": "/dashboard", "destination": "/studio-panel/", "permanent": true },
    { "source": "/dashboard/(.*)", "destination": "/studio-panel/$1", "permanent": true },
    { "source": "/studio-panel", "destination": "/studio-panel/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/debug", "destination": "/api/debug.php" },
    { "source": "/api/(.*)", "destination": "/algraphybackend/public/index.php" },
    { "source": "/auth", "destination": "/auth.html" },
    { "source": "/studio-panel/", "destination": "/studio-panel/index.html" },
    { "source": "/studio-panel/(.*)", "destination": "/studio-panel/$1" }
  ],
  "routes": [
    { "src": "/Assets/(.*)", "dest": "/Assets/$1" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/auth", "dest": "/auth.html" },
    { "src": "/studio-panel/(.*)", "dest": "/studio-panel/$1" },
    { "src": "/api/(.*)", "dest": "/algraphybackend/public/index.php" },
    { "src": "/((?!studio-panel|auth|api|Assets|css|js).*)", "dest": "/index.php" }
  ]
}
