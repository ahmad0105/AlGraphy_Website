{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    { "src": "/dashboard/(.*)", "dest": "/dashboard/index.html" },
    { "src": "/api/(.*)", "dest": "/api/core.php" },
    { "src": "/(css|js|Assets|dashboard/css|dashboard/js)/(.*)", "dest": "/$1/$2" },
    { "src": "/(.*)", "dest": "/api/main.php" }
  ]
}
