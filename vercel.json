{
  "version": 2,
  "builds": [
    {
      "src": "api/*.php",
      "use": "vercel-php",
      "config": { "includeFiles": "algraphybackend/**" }
    },
    {
      "src": "algraphybackend/public/*.php",
      "use": "vercel-php",
      "config": { "includeFiles": "algraphybackend/**" }
    },
    {
      "src": "index.php",
      "use": "vercel-php",
      "config": { "includeFiles": "algraphybackend/**" }
    },
    { "src": "dashboard/**", "use": "@vercel/static" },
    { "src": "css/**", "use": "@vercel/static" },
    { "src": "js/**", "use": "@vercel/static" },
    { "src": "Assets/**", "use": "@vercel/static" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/dashboard", "destination": "/dashboard/", "permanent": true }
  ],
  "routes": [
    { "src": "/api/debug/?", "dest": "/api/debug.php" },
    { "src": "/api/(.*)", "dest": "/algraphybackend/public/index.php" },
    { "src": "/auth", "dest": "/auth.html" },
    { "src": "/dashboard/(.*)", "dest": "/dashboard/$1" },
    { "src": "/(css|js|Assets)/(.*)", "dest": "/$1/$2" },
    { "src": "/(.*)", "dest": "/index.php" }
  ],
  "crons": [
    {
      "path": "/api/site/hero",
      "schedule": "*/10 * * * *"
    }
  ]
}
