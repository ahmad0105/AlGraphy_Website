{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2",
      "includeFiles": "algraphybackend/**"
    }
  },
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/core.php" },
    { 
      "src": "/(Assets|css|js|dashboard/css|dashboard/js|dashboard/components)/(.*)", 
      "dest": "/$1/$2",
      "headers": { "cache-control": "public, max-age=31536000, immutable" }
    },
    { "handle": "filesystem" },
    { "src": "/auth", "dest": "/auth.html" },
    { "src": "/dashboard/(.*)", "dest": "/dashboard/$1" },
    { "src": "/(.*)", "dest": "/api/main.php" }
  ],
  "crons": [
    {
      "path": "/api/site/hero",
      "schedule": "*/10 * * * *"
    }
  ]
}
