{
  "version": 2,
  "name": "algraphy-studio-v2",
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    { "src": "api/*.php", "use": "vercel-php", "config": { "includeFiles": ["algraphybackend/src/**", "algraphybackend/vendor/**"] } },
    { "src": "algraphybackend/public/*.php", "use": "vercel-php", "config": { "includeFiles": ["algraphybackend/src/**", "algraphybackend/vendor/**"] } },
    { "src": "index.php", "use": "vercel-php", "config": { "includeFiles": ["algraphybackend/src/**", "algraphybackend/vendor/**"] } },
    { "src": "studio-panel/**", "use": "@vercel/static" },
    { "src": "css/**", "use": "@vercel/static" },
    { "src": "js/**", "use": "@vercel/static" },
    { "src": "Assets/**", "use": "@vercel/static" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "redirects": [
    { "source": "/dashboard", "destination": "/studio-panel/", "permanent": true },
    { "source": "/dashboard/(.*)", "destination": "/studio-panel/$1", "permanent": true },
    { "source": "/profile", "destination": "/studio-panel/profile", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/debug", "destination": "/api/debug.php" },
    { "source": "/api/diagnose", "destination": "/api/diagnose.php" },
    { "source": "/api/(.*)", "destination": "/algraphybackend/public/index.php" },
    { "source": "/auth", "destination": "/auth.html" },
    { "source": "/studio-panel/js/(.*)", "destination": "/studio-panel/js/$1" },
    { "source": "/studio-panel/css/(.*)", "destination": "/studio-panel/css/$1" }
  ],
  "routes": [
    { "src": "/studio-panel/js/(.*)", "dest": "/studio-panel/js/$1" },
    { "src": "/studio-panel/css/(.*)", "dest": "/studio-panel/css/$1" },
    { "handle": "filesystem" },
    { "src": "/api/debug", "dest": "/api/debug.php" },
    { "src": "/api/diagnose", "dest": "/api/diagnose.php" },
    { "src": "/api/(.*)", "dest": "/algraphybackend/public/index.php" },
    { "src": "/studio-panel/(.*)", "dest": "/studio-panel/$1" },
    { "src": "/(.*)", "dest": "/index.php" }
  ],
  "crons": [
    { "path": "/api/site/hero", "schedule": "*/10 * * * *" }
  ],
  "functions": {
    "api/*.php": { "excludeFiles": "{algraphybackend/public/uploads,Assets}/**" },
    "algraphybackend/public/*.php": { "excludeFiles": "{algraphybackend/public/uploads,Assets}/**" },
    "index.php": { "excludeFiles": "{algraphybackend/public/uploads,Assets}/**" }
  }
}
