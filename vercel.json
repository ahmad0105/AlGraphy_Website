{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "*.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    { "src": "/dashboard/(.*)", "dest": "/dashboard/index.html" },
    { "src": "/algraphybackend/public/(.*)", "dest": "/algraphybackend/public/index.php" }
  ]
}
