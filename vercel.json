{
  "builds": [
    {
      "src": "api/*.php",
      "use": "vercel-php@0.7.2",
      "config": { "includeFiles": "algraphybackend/**" }
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/core.php" },
    { "src": "/auth", "dest": "/auth.html" },
    { "src": "/(Assets|css|js|dashboard)/(.*)", "dest": "/$1/$2" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/api/main.php" }
  ],
  "crons": [
    {
      "path": "/api/site/hero",
      "schedule": "*/10 * * * *"
    }
  ]
}
